{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "build-all",
            "command": "${workspaceFolder}/build-scripts/build-all.ps1",
            "options": { "cwd": "${workspaceFolder}/build-scripts" },
            "problemMatcher": [],
            "dependsOn": ["Toggle OxLint"]
        },
        {
            "type": "shell",
            "label": "clean",
            "command": "Remove-Item",
            "args": ["-Path", "${workspaceFolder}/build/*", "-Recurse"],
            "problemMatcher": []
        },
        {
            "label": "Toggle OxLint",
            "detail": "Toggles the OxLint server; to stop it to release file locks, or restart it.",
            "type": "shell",
            "command": "if (Get-Command oxlint -ErrorAction SilentlyContinue) { code --command oxc.toggleEnable --wait; Sleep(500) }",
            "problemMatcher": []
        }
    ]
}

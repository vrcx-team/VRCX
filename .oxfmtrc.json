{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "printWidth": 80,
    "tabWidth": 4,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "none",
    "bracketSpacing": true,
    "arrowParens": "always",
    "overrides": [
        {
            "files": ["*.vue"],
            "options": {
                "printWidth": 120,
                "bracketSameLine": true,
                "vueIndentScriptAndStyle": true
            }
        }
    ]
}
